# ──────────────────────────────────────────────────────────────────────────────
# Build-time environment variables
# ──────────────────────────────────────────────────────────────────────────────
# These are read during `pnpm build` (and `pnpm codegen`).
# Set them in your CI/CD dashboard (e.g. Vercel → Settings → Environment Variables)
# or in a local .env file for manual builds.
#
# On Vercel, prefix variables with VITE_ so Vite exposes them to the client bundle.
# The build scripts themselves read the unprefixed names below.

# ── Network selection ─────────────────────────────────────────────────────────
# Which network the dApp should target by default.
# Values: local | testnet | mainnet
DEVKIT_NETWORK=testnet

# Explicit chain ID override (takes precedence over DEVKIT_NETWORK lookup).
# Also accepted: PROJECT_CHAIN_ID, VITE_CHAIN_ID
DEPLOY_CHAIN_ID=71

# ── Contract addresses ────────────────────────────────────────────────────────
# Option 1: Commit deployments/contracts.json (recommended — addresses survive
# across builds without env vars).
#
# Option 2: JSON blob mapping chainId → contractName → address.
# Useful when the tracking file isn't available (CI, Vercel, etc.).
# CONTRACT_ADDRESSES='{"71":{"ExampleCounter":"0xYOUR_TESTNET_ADDRESS"}}'
#
# Option 3: Per-contract overrides (highest precedence).
# Pattern: CONTRACT_ADDRESS_<ContractName>_<chainId>=0x...
# CONTRACT_ADDRESS_ExampleCounter_71=0xYOUR_TESTNET_ADDRESS
# CONTRACT_ADDRESS_ExampleCounter_1030=0xYOUR_MAINNET_ADDRESS

# ── Vercel deployment ─────────────────────────────────────────────────────────
# Vercel auto-detects Vite. Set the root directory to the project root (not dapp/).
# Required Vercel env vars for a testnet build:
#   DEVKIT_NETWORK=testnet
#   DEPLOY_CHAIN_ID=71
#   VITE_ENABLE_SIWE=false   # static SPA on Vercel, no auth backend routes
# If deployments/contracts.json is committed with addresses, no extra vars needed.

# ── SIWE auth ─────────────────────────────────────────────────────────────────
# Controls whether the UI will call the SIWE/auth endpoints.
# Values accepted: true | false | 1 | 0 | yes | no | on | off
#
# Default behavior when unset:
#   local dev / code-server  -> enabled
#   hosted static deploy     -> disabled
#
# Set this to true only when the deployment also provides working /api/auth/*
# routes (for example, a Node server, Vercel Functions, or another backend).
VITE_ENABLE_SIWE=false
