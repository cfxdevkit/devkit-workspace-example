{
	"name": "dapp",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"codegen": "wagmi generate",
		"dev": "vite",
		"dev:proxy": "VITE_PROXY_BASE=/proxy/3001/ vite",
		"build": "vite build",
		"build:vercel": "pnpm -w run sync:network && pnpm -w run codegen && vite build",
		"build:server": "tsc -p tsconfig.server.json",
		"serve": "node dist-server/server.js"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.62.0",
		"@devkit/conflux-wallet": "workspace:*",
		"@devkit/ui-shared": "workspace:*",
		"cive": "^0.8.1",
		"react": "^18.3.0",
		"react-dom": "^18.3.0",
		"sonner": "^2.0.7",
		"viem": "^2.23.0",
		"wagmi": "^2.14.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.0",
		"@wagmi/cli": "^2.10.0",
		"autoprefixer": "^10.4.27",
		"postcss": "^8.5.8",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.7.0",
		"vite": "^6.0.0"
	},
	"license": "Apache-2.0"
}
